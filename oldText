<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Showcase Three: Emerging Expertise</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    </head>
  <body>
    <h2>Showcase Three: Emerging Expertise</h2>

    <p>
